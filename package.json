{
  "name": "webhook-relay-backend",
  "version": "1.0.0",
  "description": "Production-grade webhook relay system with retries, HMAC signing, and real-time dashboard updates",
  "main": "server.js",
  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "worker:dev": "nodemon worker.js",
    "worker": "node worker.js",
    "prisma:generate": "prisma generate --schema=src/db/prisma/schema.prisma",
    "prisma:migrate": "prisma migrate dev --schema=src/db/prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema=src/db/prisma/schema.prisma",
    "prisma:studio": "prisma studio --schema=src/db/prisma/schema.prisma",
    "seed": "node src/db/seeders/seed.js",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"src/**/*.js\""
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "axios": "^1.7.3",
    "bcrypt": "^5.1.1",
    "bullmq": "^5.12.0",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.3.2",
    "pino-http": "^10.2.0",
    "pino-pretty": "^11.2.2",
    "rate-limit-redis": "^4.2.0",
    "socket.io": "^4.7.5",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.29.1",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "prettier": "^3.3.3",
    "prisma": "^5.22.0",
    "supertest": "^7.0.0"
  }
}
