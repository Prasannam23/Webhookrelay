// src/db/prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


// USER — account that registers subscribers

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  subscribers  Subscriber[]

  @@map("users")
}


// SUBSCRIBER — a registered endpoint that wants events

model Subscriber {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  name         String                          // human label, e.g. "Prod webhook"
  targetUrl    String   @map("target_url")      // where we POST events
  secret       String                           // HMAC signing secret (encrypted at rest)
  topics       String[]                         // e.g. ["payment.success", "payment.failed"]
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  deliveryAttempts DeliveryAttempt[]

  @@index([userId])
  @@map("subscribers")
}


// EVENT — an incoming occurrence from a source system

model Event {
  id        String   @id @default(uuid())
  topic     String                              // e.g. "payment.success"
  payload   Json                                 // arbitrary event data
  createdAt DateTime @default(now()) @map("created_at")

  deliveryAttempts DeliveryAttempt[]

  @@index([topic, createdAt])
  @@map("events")
}


// DELIVERY ATTEMPT — one Event × one Subscriber, tracked through its lifecycle

enum DeliveryStatus {
  QUEUED
  RETRYING
  DELIVERED
  DEAD
}

model DeliveryAttempt {
  id               String         @id @default(uuid())
  eventId          String         @map("event_id")
  subscriberId     String         @map("subscriber_id")
  status           DeliveryStatus @default(QUEUED)
  attemptCount     Int            @default(0) @map("attempt_count")
  lastResponseCode Int?           @map("last_response_code")
  lastError        String?        @map("last_error")
  nextRetryAt      DateTime?      @map("next_retry_at")
  deliveredAt      DateTime?      @map("delivered_at")
  createdAt        DateTime       @default(now()) @map("created_at")
  updatedAt        DateTime       @updatedAt @map("updated_at")

  event      Event      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  subscriber Subscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId, status])
  @@index([eventId])
  @@map("delivery_attempts")
}